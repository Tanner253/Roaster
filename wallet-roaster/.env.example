# Solana network (mainnet-beta or devnet)
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Solana RPC (server-side)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana RPC (client-side, for wallet adapter)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API key (enriched wallet data — free tier: 100k credits/day)
HELIUS_API_KEY=

# Pump Tokenized Agent mint address (set after launching token on pump.fun)
AGENT_TOKEN_MINT_ADDRESS=

# Payment currency: wSOL (native SOL wrapped)
CURRENCY_MINT=So11111111111111111111111111111111111111112

# Price: 0.01 SOL = 10,000,000 lamports
PRICE_AMOUNT=10000000

# OpenAI API key
OPENAI_API_KEY=

# Buyback BPS (10000 = 100% of agent revenue goes to buybacks)
BUYBACK_BPS=10000
